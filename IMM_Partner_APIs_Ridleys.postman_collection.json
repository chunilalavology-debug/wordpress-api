{
  "info": {
    "_postman_id": "9b5b2c8e-3b7f-4cf7-9b6f-3c9ff4c2d1a7",
    "name": "IMM_Partner_APIs for New Ridley's Site",
    "description": "Partner APIs for Ridley's site. Uses collection variables for auth and IDs.\n\nHow to use:\n- Import this collection into Postman.\n- Set collection variables (right-click collection -> Edit -> Variables):\n  - imm_username, imm_password, imm_client_id, imm_shopper_id, imm_loyalty_card, imm_store_id\n  - kacu_apikey, kacu_apisecret, kacu_clientid, kacu_companyid, kacu_storeid, kacu_loyaltycard\n- Run \"Get Partner Token\" first. It writes imm_access_token automatically.\n- Then run the other requests.\n\nNotes:\n- Token endpoint expects credentials in HEADERS (username/password/ClientID) and grant_type in x-www-form-urlencoded body.\n- Offers calls expect Authorization: Bearer {{imm_access_token}} and ClientID header.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "IMM (prt-ridstaging.immapi.com)",
      "item": [
        {
          "name": "Get Partner Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" },
              { "key": "username", "value": "{{imm_username}}" },
              { "key": "password", "value": "{{imm_password}}" },
              { "key": "ClientID", "value": "{{imm_client_id}}" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "password", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{imm_base_url}}/Api/V3.0/token",
              "host": [ "{{imm_base_url}}" ],
              "path": [ "Api", "V3.0", "token" ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Token request succeeded', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "try {",
                  "  const json = pm.response.json();",
                  "  if (json && json.access_token) {",
                  "    pm.collectionVariables.set('imm_access_token', json.access_token);",
                  "    if (json.expires_in) pm.collectionVariables.set('imm_expires_in', String(json.expires_in));",
                  "    if (json['.expires']) pm.collectionVariables.set('imm_expires_at', json['.expires']);",
                  "  }",
                  "} catch (e) {}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Offers",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{imm_access_token}}" },
              { "key": "ClientID", "value": "{{imm_client_id}}" }
            ],
            "url": {
              "raw": "{{imm_base_url}}/Api/V3.0/api/v4.0/Offers?shopperID={{imm_shopper_id}}&offertype={{imm_offer_type}}",
              "host": [ "{{imm_base_url}}" ],
              "path": [ "Api", "V3.0", "api", "v4.0", "Offers" ],
              "query": [
                { "key": "shopperID", "value": "{{imm_shopper_id}}" },
                { "key": "offertype", "value": "{{imm_offer_type}}" }
              ]
            }
          }
        },
        {
          "name": "Get Stores",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{imm_access_token}}" },
              { "key": "ClientID", "value": "{{imm_client_id}}" }
            ],
            "url": {
              "raw": "{{imm_base_url}}{{imm_get_stores_path}}",
              "host": [ "{{imm_base_url}}" ],
              "path": [],
              "query": []
            }
          }
        },
        {
          "name": "Get Collection Offers (DigitalOffers)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{imm_access_token}}" },
              { "key": "ClientID", "value": "{{imm_client_id}}" }
            ],
            "url": {
              "raw": "{{imm_base_url}}/Api/V3.0/api/v4.0/Offers/CollectionOffers?shopperID={{imm_shopper_id}}&Collection={{imm_collection}}",
              "host": [ "{{imm_base_url}}" ],
              "path": [ "Api", "V3.0", "api", "v4.0", "Offers", "CollectionOffers" ],
              "query": [
                { "key": "shopperID", "value": "{{imm_shopper_id}}" },
                { "key": "Collection", "value": "{{imm_collection}}" }
              ]
            }
          }
        },
        {
          "name": "Get ShopperDetails",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{imm_access_token}}" },
              { "key": "shopperID", "value": "{{imm_shopper_id}}" },
              { "key": "ClientID", "value": "{{imm_client_id}}" }
            ],
            "url": {
              "raw": "{{imm_base_url}}/Api/V3.0/Shopper",
              "host": [ "{{imm_base_url}}" ],
              "path": [ "Api", "V3.0", "Shopper" ]
            }
          }
        },
        {
          "name": "Clip Offer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{imm_access_token}}" },
              { "key": "ClientID", "value": "{{imm_client_id_clip}}" },
              { "key": "ShopperID", "value": "{{imm_shopper_id}}" },
              { "key": "ClickType", "value": "2" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"Items\": [\n    {\n      \"CouponID\": \"{{imm_coupon_id}}\",\n      \"ClippedDate\": \"{{imm_clipped_date}}\"\n    }\n  ]\n}\n",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{imm_base_url}}/Api/V3.0/api/v4.0/Coupon/Click",
              "host": [ "{{imm_base_url}}" ],
              "path": [ "Api", "V3.0", "api", "v4.0", "Coupon", "Click" ]
            }
          }
        },
        {
          "name": "Store Update",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{imm_access_token}}" },
              { "key": "ClientID", "value": "{{imm_client_id}}" }
            ],
            "url": {
              "raw": "{{imm_base_url}}/Api/V3.0/api/v4.0/ShopperUpdateStore?StoreId={{imm_store_id}}&ShopperId={{imm_shopper_id}}",
              "host": [ "{{imm_base_url}}" ],
              "path": [ "Api", "V3.0", "api", "v4.0", "ShopperUpdateStore" ],
              "query": [
                { "key": "StoreId", "value": "{{imm_store_id}}" },
                { "key": "ShopperId", "value": "{{imm_shopper_id}}" }
              ]
            }
          }
        }
        ,
        {
          "name": "LoginSSO",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{imm_access_token}}" },
              { "key": "ClientID", "value": "{{imm_client_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{imm_email}}\",\n  \"phone\": \"{{imm_phone}}\",\n  \"shopperID\": \"{{imm_shopper_id}}\",\n  \"loyaltyCard\": \"{{imm_loyalty_card}}\"\n}\n",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{imm_base_url}}{{imm_login_sso_path}}",
              "host": [ "{{imm_base_url}}" ],
              "path": [],
              "query": []
            }
          },
          "description": "Set imm_login_sso_path to your LoginSSO endpoint path. Example might be /Api/V3.0/api/v4.0/LoginSSO. Adjust body fields to match your spec."
        }
      ]
    },
    {
      "name": "KACU Cashback (stagingclientapi.kacu.app)",
      "item": [
        {
          "name": "Get Cashback Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Apikey", "value": "{{kacu_apikey}}" },
              { "key": "ApiSecret", "value": "{{kacu_apisecret}}" },
              { "key": "ClientID", "value": "{{kacu_clientid}}" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "password", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{kacu_base_url}}/API/V1.0/Token",
              "host": [ "{{kacu_base_url}}" ],
              "path": [ "API", "V1.0", "Token" ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Cashback token request succeeded', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "try {",
                  "  const json = pm.response.json();",
                  "  if (json && json.access_token) {",
                  "    pm.collectionVariables.set('kacu_access_token', json.access_token);",
                  "    if (json.expires_in) pm.collectionVariables.set('kacu_expires_in', String(json.expires_in));",
                  "    if (json['.expires']) pm.collectionVariables.set('kacu_expires_at', json['.expires']);",
                  "  }",
                  "} catch (e) {}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Cashback Offers (All)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{kacu_access_token}}" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "ShopperProfileID", "value": "{{kacu_shopperprofileid}}", "type": "text" },
                { "key": "CompanyID", "value": "{{kacu_companyid}}", "type": "text" },
                { "key": "StoreID", "value": "{{kacu_storeid}}", "type": "text" },
                { "key": "LoyaltyCard", "value": "{{kacu_loyaltycard}}", "type": "text" },
                { "key": "ShopperID", "value": "{{kacu_shopperid}}", "type": "text" }
              ]
            },
            "url": {
              "raw": "{{kacu_base_url}}/API/V1.0/Offers/All",
              "host": [ "{{kacu_base_url}}" ],
              "path": [ "API", "V1.0", "Offers", "All" ]
            }
          }
        }
      ]
    }
  ],
